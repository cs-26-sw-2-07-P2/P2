datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ======================
// AUTH / USERS
// ======================
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())

  employee Employee?
  manager  Manager?
}

model Employee {
  id     Int @id @default(autoincrement())
  userId Int @unique

  user User @relation(fields: [userId], references: [id])

  responses Response[]
}

model Manager {
  id     Int @id @default(autoincrement())
  userId Int @unique

  user           User            @relation(fields: [userId], references: [id])
  questionnaires Questionnaire[]
}

model Parameter {
  id   Int    @id @default(autoincrement())
  name String

  questions     Question[]
  jobParameters JobParameter[]
}

// Job (type) / Department
model Job {
  id   Int    @id @default(autoincrement())
  name String

  parameters JobParameter[]
}

model JobParameter {
  id Int @id @default(autoincrement())

  jobId       Int
  parameterId Int

  weight Int // 1–5 importance

  job       Job       @relation(fields: [jobId], references: [id])
  parameter Parameter @relation(fields: [parameterId], references: [id])

  @@unique([jobId, parameterId])
}

// ======================
// QUESTIONNAIRE SYSTEM
// ======================
model Questionnaire {
  id          Int      @id // There can only be one quesitonnaire
  title       String
  createdAt   DateTime @default(now())
  createdById Int
  createdBy   Manager  @relation(fields: [createdById], references: [id])

  questions Question[]
}

model Question {
  id   Int    @id @default(autoincrement())
  text String

  questionnaireId Int
  parameterId     Int

  questionnaire Questionnaire @relation(fields: [questionnaireId], references: [id])
  parameter     Parameter     @relation(fields: [parameterId], references: [id])

  responses Response[]
}

model Response {
  id Int @id @default(autoincrement())

  value Int

  employeeId Int
  questionId Int

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([employeeId, questionId])
}

enum Role {
  EMPLOYEE
  MANAGER
}
